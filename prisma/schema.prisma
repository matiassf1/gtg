generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPRESA
  CLIENTE
  ADMIN
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(CLIENTE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  restaurant    Restaurant?
  client        Client?
  notifications Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Negocio ─────────────────────────────────────────────────────────────────

enum PromotionType {
  DESCUENTO
  DOS_X_UNO
  MENU_ESPECIAL
  OTRO
}

enum ReservationStatus {
  PENDIENTE
  CONFIRMADA
  RECHAZADA
  COMPLETADA
  CANCELADA
}

model Restaurant {
  id            String   @id @default(cuid())
  userId        String   @unique
  name          String
  description   String?  @db.Text
  category      String
  address       String
  city          String
  phone         String?
  photos        String[]
  priceRange    Int?
  latitude      Float?
  longitude     Float?
  openingHours  Json?
  capacity      Int?
  averageRating Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoritedBy  Client[]      @relation("ClientFavorites")
  menuItems    MenuItem[]
  reservations Reservation[]
  promotions   Promotion[]
  reviews      Review[]

  @@map("restaurants")
}

model MenuItem {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  description  String?  @db.Text
  price        Float
  image        String?
  category     String
  available    Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model Client {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites    Restaurant[]  @relation("ClientFavorites")
  reservations Reservation[]
  reviews      Review[]
  benefits     Benefit[]

  @@map("clients")
}

model Reservation {
  id           String            @id @default(cuid())
  restaurantId String
  clientId     String
  date         DateTime
  guests       Int
  status       ReservationStatus @default(PENDIENTE)
  notes        String?           @db.Text
  rejectReason String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model Promotion {
  id              String        @id @default(cuid())
  restaurantId    String
  title           String
  description     String?       @db.Text
  type            PromotionType
  discountPercent Float?
  validFrom       DateTime
  validUntil      DateTime
  conditions      String?       @db.Text
  active          Boolean       @default(true)
  usageCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  benefits   Benefit[]

  @@map("promotions")
}

model Review {
  id           String   @id @default(cuid())
  restaurantId String
  clientId     String
  rating       Int
  comment      String?  @db.Text
  response     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ─── Notificaciones ──────────────────────────────────────────────────────────

enum NotificationType {
  RESERVA_NUEVA
  RESERVA_CONFIRMADA
  RESERVA_RECHAZADA
  NUEVA_RESENA
  PROMOCION
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─── Beneficios ───────────────────────────────────────────────────────────────

enum BenefitStatus {
  DISPONIBLE
  CANJEADO
  EXPIRADO
}

model Benefit {
  id          String        @id @default(cuid())
  clientId    String
  promotionId String
  status      BenefitStatus @default(DISPONIBLE)
  redeemedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([clientId, promotionId])
  @@map("benefits")
}
